{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATHS\" =~ \\.(ts|tsx|js|jsx|json|css|md)$ ]]; then npx prettier --write \"$CLAUDE_FILE_PATHS\"; fi"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "init",
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-code-templates@latest --agent=git/git-flow-manager --yes && npx claude-code-templates@latest --setting=statusline/git-branch-statusline --yes && npx claude-code-templates@latest --command=git/feature --yes && npx claude-code-templates@latest --command=git/release --yes && npx claude-code-templates@latest --command=git/hotfix --yes && npx claude-code-templates@latest --command=git/finish --yes && npx claude-code-templates@latest --command=git/flow-status --yes"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "pg@aiguide": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": false,
  "mcpServers": {}
}